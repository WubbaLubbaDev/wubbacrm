# WubbaCRM Environment Variables
# Copy this file to .env.local and fill in your values.
# See README.md > "Environment Variables" for full descriptions and where to get each value.

# ─── Frontend (loaded by Vite, safe for the browser) ───────────────────────

# Supabase project URL
# Source: Supabase Dashboard > Settings > API (Project URL)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable/anon key (client-side safe)
# Source: Supabase Dashboard > Settings > API Keys (publishable key)
VITE_SUPABASE_ANON_KEY=your-publishable-key-here

# Google OAuth 2.0 client ID (public, safe for frontend)
# Source: Google Cloud Console > APIs & Services > Credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# ─── Server-side secrets (Supabase Edge Functions) ─────────────────────────
# These do NOT go in .env.local. Set them via:
#   supabase secrets set KEY=VALUE
# or Supabase Dashboard > Edge Functions > Secrets.
# NEVER commit these to the repo.
#
#   GOOGLE_CLIENT_ID           — same OAuth client ID as VITE_GOOGLE_CLIENT_ID above
#   GOOGLE_CLIENT_SECRET       — OAuth client secret (server-side only)
#   GOOGLE_REDIRECT_URI        — must match the frontend redirect URI exactly
#                                (e.g. http://localhost:5173/oauth/google-calendar/callback)
#
# Auto-injected by Supabase (do NOT set these as custom secrets —
# the SUPABASE_ prefix is reserved):
#   SUPABASE_URL               — your Supabase project URL (same as VITE_SUPABASE_URL)
#   SUPABASE_SECRET_KEYS       — JSON dict of secret keys; ['default'] is the
#                                service role key used by Edge Functions (bypasses RLS)

# ─── Redirect URI note ─────────────────────────────────────────────────────
# The OAuth redirect URI is derived automatically from window.location.origin
# at runtime as <origin>/oauth/google-calendar/callback.
# There is no VITE_GOOGLE_REDIRECT_URI env var — just make sure the redirect
# URI for your environment is listed in Google Cloud Console >
# Authorized redirect URIs.