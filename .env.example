# WubbaCRM Environment Variables
# Copy this file to .env.local and fill in your Supabase project details

# Supabase Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase publishable/anon key (client-side safe)
# Find this in your Supabase Dashboard: Settings > API Keys
VITE_SUPABASE_ANON_KEY=your-publishable-key-here

# Google OAuth client ID (public, safe for frontend)
# Create at https://console.cloud.google.com/ > APIs & Services > Credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# NOTE: The OAuth redirect URI is derived automatically from window.location.origin
# at runtime as <origin>/settings/integrations/google-calendar/callback.
# There is no VITE_GOOGLE_REDIRECT_URI env var — just make sure the redirect URI
# for your environment is listed in Google Cloud Console > Authorized redirect URIs.
#
# The following server-side secrets are required by the Supabase Edge Functions
# (google-oauth-exchange, google-oauth-disconnect, google-token-refresh).
# Set them via `supabase secrets set KEY=VALUE` — NEVER put them in .env.local:
#   GOOGLE_CLIENT_ID           — same OAuth client ID as above
#   GOOGLE_CLIENT_SECRET       — OAuth client secret (server-side only)
#   GOOGLE_REDIRECT_URI        — must match the frontend redirect URI exactly
#   SUPABASE_URL               — your Supabase project URL
#   SUPABASE_SERVICE_ROLE_KEY  — Supabase service role key